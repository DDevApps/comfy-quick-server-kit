USER_NAME=your-user
COMFY_PATH=/home/your-user/ComfyUI
CONDA_SH=/home/your-user/miniconda3/etc/profile.d/conda.sh
CONDA_ENV=comfy

PANEL_PORT=3001
COMFY_PORT=8188

PANEL_TOKEN=change-this-token
PANEL_NAME=comfy-panel

LOG_DIR=/home/your-user/logs

COMFY_SERVICE_NAME=comfyui

TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
DISCORD_WEBHOOK_URL=

COMFY_ARGS="--listen 0.0.0.0 --port 8188 --lowvram --cache-none --reserve-vram 6 --preview-method none"